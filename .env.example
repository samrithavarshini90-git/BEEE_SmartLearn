# Copy this file to .env and fill in your values.
# Do NOT commit .env — it contains real secrets.

# TiDB Cloud Serverless database URL
# Get this from: https://tidbcloud.com → your cluster → Connect
TIDB_URL="mysql://user:password@gateway.tidbcloud.com:4000/beee"

# Cerebras AI API keys (comma-separated list for rotation)
# Get this from: https://cloud.cerebras.ai
CEREBRAS_API_KEYS="csk-key1,csk-key2,csk-key3"
CEREBRAS_VISION_KEYS="csk-visionkey1,csk-visionkey2"

# JWT session secret — use a long random string in production
JWT_SECRET="change-this-to-a-long-random-string"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

